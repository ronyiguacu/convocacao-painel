{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Convocacao Painel",
  "version": "1.0.3",
  "identifier": "com.iguacu.convocacao.painel",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Convocação",
        "url": "https://painel-servidor.onrender.com/cosmo.html",
        "width": 400,
        "height": 800,
        "resizable": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ronyiguacu/convocacao-painel/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxRDlBQUI2OEE0Qzc2QkEKUldTNmRreUt0cXJaMFNnQnJNNnZtNVhJeVViY2JKbXNUZWJhRmlSYmZ6MkV0K3JYUllxbldSZ2YK"
    }
  }
}
